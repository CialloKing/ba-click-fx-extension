{
  "name": "ba-click-fx-extension",
  "version": "1.0.5",
  "description": "BA Click FX 的 Manifest V3 浏览器扩展。",
  "private": true,
  "type": "module",
  "engines":
  {
    "node": ">=22"
  },
  "scripts":
  {
    "build": "node scripts/build.mjs",
    "check": "node --test && node scripts/validate-build.mjs && node scripts/validate-store-assets.mjs && node scripts/encoding.mjs",
    "check:release": "node scripts/validate-release.mjs",
    "check:store": "node scripts/validate-store-assets.mjs",
    "check:encoding": "node scripts/encoding.mjs",
    "format:encoding": "node scripts/encoding.mjs --write",
    "package": "npm run build && node scripts/package.mjs",
    "test": "npm run build && npm run check"
  },
  "dependencies":
  {
    "ba-click-fx": "1.1.11"
  },
  "devDependencies":
  {
    "esbuild": "0.28.1",
    "fflate": "0.8.3"
  }
}
